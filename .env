# Backend AI Configuration settings

# Option 1: Local LLM (Ollama)
# Set to 'true' to use a local, free Ollama model without needing an API key. 
# Make sure Ollama is installed and running on your PC (http://localhost:11434).
# Set to 'false' if you want to use OpenAI instead.
USE_LOCAL_LLM=true
OPENAI_MODEL=llama3

# Option 2: OpenAI API
# If USE_LOCAL_LLM is set to 'false', the system will use OpenAI.
# Insert your real API key here:
OPENAI_API_KEY=sk-your-openai-api-key-here
